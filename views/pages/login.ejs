<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <title>
    Noir Home | Login
  </title>

  <link
    rel="stylesheet"
    href="/css/style.css"
  >

  <link
    rel="preconnect"
    href="https://fonts.googleapis.com"
  >

  <link
    rel="preconnect"
    href="https://fonts.gstatic.com"
    crossorigin
  >

  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=Inter:wght@300;400;500&display=swap"
    rel="stylesheet"
  >

</head>

<body class="login-page">

  <!-- BACKGROUND IMAGE -->

  <div class="login-hero">

    <img
      src="/images/login-bg.jpg"
      alt="Luxury Interior"
    >

  </div>

  <!-- LOGIN CARD -->

  <div class="login-container">

    <form
      action="/login"
      method="POST"
      class="luxury-login"
    >

      <p class="login-tag">
        NOIR HOME
      </p>

      <h1>
        Welcome Back
      </h1>

      <p class="login-text">

        Sign into your account to continue exploring
        our curated luxury collection.

      </p>

      <input
        type="email"
        name="email"
        placeholder="Email Address"
        required
      >

      <input
        type="password"
        name="password"
        placeholder="Password"
        required
      >

      <button type="submit">

  <span>
    Login
  </span>

</button>

      <a
        href="/register"
        class="register-link"
      >

        Create an account

      </a>

    </form>

  </div>

</body>

</html>